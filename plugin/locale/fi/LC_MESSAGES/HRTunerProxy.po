#: ../plugin.py:219 ../plugin.py:277 ../plugin.py:301 ../plugin.py:318
msgid "IP address or hostname to use."
msgstr "Käytettävä IP-osoite tai isäntänimi."

#: ../getDeviceInfo.py:96
msgid "In use"
msgstr "Käytössä"

#: ../plugin.py:369
msgid "It seems you have already set up another tuner. Your server can only support one tuner type. To use this additional tuner type you will need to setup another server. Do you want to continue creating the files?"
msgstr "Näyttää siltä, ​​että olet jo asentanut toisen virittimen. Palvelimesi tukee vain yhtä viritintyyppiä. Tämän lisäviritintyypin käyttämiseksi sinun on määritettävä toinen palvelin. Haluatko jatkaa tiedostojen luomista?"

#: ../plugin.py:279 ../plugin.py:302 ../plugin.py:319
msgid "Leave empty to use the detected IP address."
msgstr "Jätä kenttä tyhjäksi, jos haluat käyttää tunnistettua IP-osoitetta."

#: ../plugin.py:366
msgid "No IP address found. Please enter an IP address or hostname."
msgstr "IP-osoitetta ei löytynyt. Syötä IP-osoite tai isäntänimi."

#: ../__init__.py:72
msgid "Not set"
msgstr "Ei asetettu"

#: ../plugin.py:222
msgid "Number of concurrent streams."
msgstr "Samanaikaisten streamien määrä."

#: ../plugin.py:291
msgid ""
"Please note: DVR feature in Plex / Emby is a premium / premiere feature. For more information please refer to:\n"
"https://www.plex.tv/features/plex-pass\n"
"https://emby.media/premiere.html"
msgstr ""
"Huomio: DVR-toiminto Plex:ssa / Emby:ssa on lisähintainen toiminto. Lisätietoja:\n"
"https://www.plex.tv/features/plex-pass\n"
"https://emby.media/premiere.html"

#: ../plugin.py:259
msgid "Please note: Please now select a bouquet to use."
msgstr "Huomio: Valitse käytettävä suosikkilista."

#: ../plugin.py:295
msgid ""
"Please note: To use another tuner type in Plex you need to setup/have another server.\n"
"Are you sure you want to continue?"
msgstr ""
"Huomio: käyttääksesi toista viritintyyppiä Plex:ssa, täytyy asentaa/olla toinen serveri.\n"
"Haluatko varmasti jatkaa?"

#: ../plugin.py:261
msgid "Please note: You do not seem to have any channels setup for this tuner, please add some channels to Enigma2 or choose anther tuner type."
msgstr "Huomio: Näyttää, että yhtään kanavaa ei ole määritetty tälle virittimelle. Lisää kanavia Enigma2:lle tai valitse eri viritintyyppi."

#: ../plugin.py:308 ../plugin.py:325
msgid "Press LEFT / RIGHT to enable or disable debug mode."
msgstr "Paina VASEN / OIKEA salliaksesi tai estääksesi debug-moodin."

#: ../plugin.py:282 ../plugin.py:285 ../plugin.py:305 ../plugin.py:322
msgid "Press LEFT / RIGHT to select a different bouquet."
msgstr "Paina VASEN / OIKEA valitaksesi eri suosikkilistan."

#: ../plugin.py:276 ../plugin.py:299 ../plugin.py:316
msgid "Press LEFT / RIGHT to select a different tuner type."
msgstr "Paina VASEN / OIKEA valitaksesi eri viritintyypin."

#: ../plugin.py:288
msgid "Press LEFT / RIGHT to set number of concurent streams."
msgstr "Paina VASEN / OIKEA asettaaksesi samanaikaisten streamien määrän."

#: ../plugin.py:278
msgid "Press OK to continue setting up this tuner or enter an IP address or hostname."
msgstr "Paina OK jatkaaksesi tämän virittimen asennusta tai syöttääksesi IP-osoitteen tai isäntänimen."

#: ../plugin.py:275
msgid "Press OK to continue setting up this tuner or press LEFT / RIGHT to select a different tuner type."
msgstr "Paina OK jatkaaksesi tämään virittimen asennusta tai paina VASEN / OIKEA valitaksesi eri viritintyypin."

#: ../plugin.py:281 ../plugin.py:284 ../plugin.py:287
msgid "Press OK to continue setting up this tuner or select a different tuner type."
msgstr "Paina OK jatkaaksesi tämän virittimen asennusta tai valitse toinen viritintyyppi."

#: ../plugin.py:268
msgid "Press OK to continue setting up this tuner."
msgstr "Paina OK jatkaaksesi tämän virittimen asennusta."

#: ../plugin.py:292
msgid "Press OK to continue setting up."
msgstr "Paina OK jatkaaksesi asennusta."

#: ../plugin.py:408
msgid "Really close without saving settings?"
msgstr "Suljetaanko todella ilman asetusten tallennusta?"

#: ../plugin.py:271 ../plugin.py:311 ../plugin.py:326
msgid "Save"
msgstr "Tallenna"

#: ../plugin.py:476 ../plugin.py:477 ../plugin.py:478
